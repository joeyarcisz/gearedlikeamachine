generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActivityType {
  note
  email_sent
  call
  meeting
  stage_change
  created
  updated
}

enum ContactStage {
  lead
  qualifying
  active_contact
  active_conversation
  client_account
  client_past
  inactive_contact
}

enum OpportunityStage {
  lead
  qualification
  proposal
  negotiation
  waiting_client_feedback
  nurture_reactivation
  won
  lost
  deferred
}

model Contact {
  id             String       @id @default(cuid())
  name           String
  company        String?
  email          String?
  phone          String?
  stage          ContactStage @default(lead)
  lastContact    DateTime?
  nextAction     String?
  notes          String?
  sourceFiles    String?
  blogSubscriber Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  opportunities Opportunity[]
  activities    Activity[]
  projects      Project[]
}

model Opportunity {
  id                 String           @id @default(cuid())
  title              String
  company            String?
  stage              OpportunityStage @default(lead)
  estimatedValueLow  Int?
  estimatedValueHigh Int?
  lastTouch          DateTime?
  nextAction         String?
  owner              String?
  priority           String?
  notes              String?
  contactId          String?
  contact            Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  activities         Activity[]
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType
  description   String
  metadata      Json?
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  crewMemberId  String?
  crewMember    CrewMember?  @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
}

model CrewMember {
  id          String    @id @default(cuid())
  name        String
  email       String?   @unique
  phone       String?
  role        String
  dayRate     Int?
  kitFee      Int?
  notes       String?
  city        String?
  state       String?
  website     String?
  instagram   String?
  imdb        String?
  w9OnFile    Boolean   @default(false)
  ndaOnFile   Boolean   @default(false)
  rating      Int?
  lastBooked  DateTime?
  tags        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  activities  Activity[]

  crewCalls              CrewCall[]
  scheduleAssignments    ScheduleCrewAssignment[]
  projectCrew            ProjectCrew[]
  crewInvoices           CrewInvoice[]
}

// ═══════════════════════════════════════════════════════
// PRODUCTION MANAGEMENT
// ═══════════════════════════════════════════════════════

enum ProjectStatus {
  pre_production
  production
  post_production
  wrap
  archived
}

model Project {
  id            String        @id @default(cuid())
  title         String
  clientName    String?
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  status        ProjectStatus @default(pre_production)
  projectType   String?
  description   String?
  startDate     DateTime?
  endDate       DateTime?
  budgetLow     Int?
  budgetHigh    Int?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  callSheets       CallSheet[]
  shotLists        ShotList[]
  scheduleDays     ScheduleDay[]
  projectCrew      ProjectCrew[]
  projectEquipment ProjectEquipment[]
  documents        Document[]
}

// ── Call Sheets ──

enum CallSheetStatus {
  draft
  sent
  confirmed
}

model CallSheet {
  id                  String          @id @default(cuid())
  projectId           String
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shootDate           DateTime
  callTime            String
  wrapTime            String?
  locationName        String?
  locationAddress     String?
  parkingNotes        String?
  nearestHospital     String?
  weatherSummary      String?
  weatherTemp         String?
  sunrise             String?
  sunset              String?
  generalNotes        String?
  specialInstructions String?
  status              CallSheetStatus @default(draft)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  crewCalls CrewCall[]
}

model CrewCall {
  id           String      @id @default(cuid())
  callSheetId  String
  callSheet    CallSheet   @relation(fields: [callSheetId], references: [id], onDelete: Cascade)
  crewMemberId String?
  crewMember   CrewMember? @relation(fields: [crewMemberId], references: [id], onDelete: SetNull)
  name         String
  role         String
  callTime     String
  notes        String?
}

// ── Shot Lists ──

model ShotList {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  sceneNumber String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shots Shot[]
}

model Shot {
  id          String   @id @default(cuid())
  shotListId  String
  shotList    ShotList @relation(fields: [shotListId], references: [id], onDelete: Cascade)
  shotNumber  String
  size        String?
  movement    String?
  angle       String?
  lens        String?
  frameRate   String?
  equipment   String?
  lighting    String?
  description String
  imageUrl    String?
  notes       String?
  completed   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Scheduling ──

model ScheduleDay {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date            DateTime
  startTime       String
  wrapTime        String?
  locationName    String?
  locationAddress String?
  notes           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  crewAssignments      ScheduleCrewAssignment[]
  equipmentAssignments ScheduleEquipmentAssignment[]
}

model ScheduleCrewAssignment {
  id            String      @id @default(cuid())
  scheduleDayId String
  scheduleDay   ScheduleDay @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)
  crewMemberId  String?
  crewMember    CrewMember? @relation(fields: [crewMemberId], references: [id], onDelete: SetNull)
  name          String
  role          String
  callTime      String?
  rate          Int?
  notes         String?
}

model ScheduleEquipmentAssignment {
  id            String      @id @default(cuid())
  scheduleDayId String
  scheduleDay   ScheduleDay @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)
  itemName      String
  category      String?
  quantity      Int         @default(1)
  notes         String?
}

// ── Project Team & Gear ──

model ProjectCrew {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crewMemberId String?
  crewMember   CrewMember? @relation(fields: [crewMemberId], references: [id], onDelete: SetNull)
  name         String
  role         String
  dayRate      Int?
  kitFee       Int?
  notes        String?
  createdAt    DateTime    @default(now())
}

model ProjectEquipment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  itemName  String
  category  String?
  dailyRate Int?
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// ═══════════════════════════════════════════════════════
// DOCUMENT MANAGEMENT
// ═══════════════════════════════════════════════════════

enum DocumentCategory {
  LEGAL
  PRODUCTION
  FINANCIAL
  CREW
}

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  COMPLETED
  EXPIRED
  CANCELLED
}

enum CrewInvoiceStatus {
  SENT
  RETURNED
  PAID
}

enum PaymentMethod {
  ACH
  ZELLE
  CHECK
  WIRE
  PAYPAL
  VENMO
}

model DocumentTemplate {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  category          DocumentCategory
  description       String
  requiresSignature Boolean          @default(true)
  isExternal        Boolean          @default(false)
  fieldSchema       Json
  defaultValues     Json?
  documents         Document[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Document {
  id             String           @id @default(cuid())
  templateId     String
  template       DocumentTemplate @relation(fields: [templateId], references: [id])
  projectId      String?
  project        Project?         @relation(fields: [projectId], references: [id])
  token          String           @unique @default(uuid())
  status         DocumentStatus   @default(DRAFT)
  formData       Json             @default("{}")
  recipientName  String?
  recipientEmail String?
  completedAt    DateTime?
  expiresAt      DateTime?
  signature      Signature?
  crewInvoice    CrewInvoice?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([templateId])
  @@index([projectId])
}

model Signature {
  id         String   @id @default(cuid())
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerName String
  signerIP   String
  userAgent  String
  agreedAt   DateTime @default(now())
}

model CrewInvoice {
  id             String            @id @default(cuid())
  documentId     String            @unique
  document       Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  crewMemberId   String
  crewMember     CrewMember        @relation(fields: [crewMemberId], references: [id])
  paymentMethod  PaymentMethod?
  paymentDetails Json?
  status         CrewInvoiceStatus @default(SENT)
  paidAt         DateTime?
  paidNote       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}
